<!-- Popup Diagnóstico Clima 360 -->
<style>
  #diag360backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 2147483646;
    background: rgba(0,0,0,0.55);
    -webkit-tap-highlight-color: transparent;
  }
  #diag360backdrop.show { display: block; }
  #diag360pop {
    display: none;
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 2147483647;
    width: 320px;
    max-width: calc(100vw - 32px);
    border-radius: 20px;
    background: linear-gradient(145deg, #111827, #0f172a);
    border: 1px solid rgba(14,165,233,0.4);
    box-shadow: 0 24px 64px rgba(0,0,0,0.7);
    padding: 24px;
    font-family: Arial, sans-serif;
    color: #f1f5f9;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }
  #diag360pop.show {
    display: block !important;
    animation: d360in 0.4s cubic-bezier(0.34,1.56,0.64,1) forwards;
  }
  @keyframes d360in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  #d360close {
    position: absolute; top: 12px; right: 14px;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
    border-radius: 50%; width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: #94a3b8; font-size: 14px; line-height: 1;
  }
  #d360close:hover { background: rgba(255,255,255,0.15); color: #fff; }
  .d360badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 10px; border-radius: 999px;
    background: rgba(14,165,233,0.12); border: 1px solid rgba(14,165,233,0.35);
    color: #38bdf8; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 14px;
  }
  .d360dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #0ea5e9; box-shadow: 0 0 6px #0ea5e9;
    animation: d360pulse 1.8s infinite;
  }
  @keyframes d360pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
  .d360title { font-size: 16px; font-weight: 800; line-height: 1.3; margin: 0 0 8px; color: #f1f5f9; }
  .d360text  { font-size: 13px; color: #64748b; line-height: 1.55; margin: 0 0 14px; }
  .d360items { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
  .d360item  { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #94a3b8; }
  .d360item::before {
    content: "✓"; min-width: 18px; height: 18px; border-radius: 5px;
    background: rgba(14,165,233,0.15); color: #38bdf8; font-size: 11px;
    font-weight: 900; display: flex; align-items: center; justify-content: center;
  }
  .d360cta {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 13px 20px; border-radius: 12px; border: 0;
    background: linear-gradient(135deg, #0ea5e9, #38bdf8);
    color: #fff !important; font-weight: 700; font-size: 14px;
    cursor: pointer; text-decoration: none !important;
    box-shadow: 0 6px 20px rgba(14,165,233,0.35); margin-bottom: 10px;
  }
  .d360cta:hover { opacity: 0.9; }
  .d360skip {
    display: block; text-align: center; color: #475569; font-size: 12px;
    cursor: pointer; background: none; border: 0; width: 100%;
    font-family: Arial, sans-serif; padding: 4px;
  }
  .d360skip:hover { color: #94a3b8; }
  @media (max-width: 767px) {
    #diag360pop {
      top: 50%;
      bottom: auto;
      left: 16px;
      right: 16px;
      width: auto;
      max-width: 100%;
      transform: translateY(-50%);
      border-radius: 20px;
      padding: 20px;
      box-shadow: 0 12px 48px rgba(0,0,0,0.6);
    }
    #diag360pop.show {
      animation: d360in-mobile 0.4s cubic-bezier(0.34,1.56,0.64,1) forwards;
    }
    @keyframes d360in-mobile {
      from { opacity: 0; transform: translateY(calc(-50% + 20px)); }
      to   { opacity: 1; transform: translateY(-50%); }
    }
  }
</style>

<div id="diag360backdrop" aria-hidden="true"></div>
<div id="diag360pop">
  <button id="d360close" type="button" aria-label="Fechar">&#x2715;</button>
  <div class="d360badge"><span class="d360dot"></span> Novo</div>
  <p class="d360title">Qual ar-condicionado é ideal para você?</p>
  <p class="d360text">Responda 10 perguntas e descubra a recomendação certa para o seu ambiente.</p>
  <div class="d360items">
    <span class="d360item">BTUs ideais para o seu ambiente</span>
    <span class="d360item">Perfil personalizado de climatização</span>
    <span class="d360item">Link direto para os produtos certos</span>
  </div>
  <a class="d360cta" href="/pagina/diagnostico-360">&#127777; Fazer diagnóstico grátis</a>
  <button class="d360skip" id="d360skip" type="button">Agora não</button>
</div>

<script>
(function(){
  try {
    var KEY = 'diag360_shown_session';
    function isDiagPage() {
      var p = (window.location.pathname || '').toLowerCase();
      return p.indexOf('diagnostico') !== -1 || p.indexOf('diag360') !== -1;
    }
    function isMobile() {
      return window.matchMedia('(max-width: 767px)').matches;
    }
    function jaViu() {
      try { return sessionStorage.getItem(KEY) === '1'; } catch(e) { return false; }
    }
    function marcarVisto() {
      try { sessionStorage.setItem(KEY, '1'); } catch(e) {}
    }
    if (jaViu()) return;
    if (isDiagPage()) return;
    var el = document.getElementById('diag360pop');
    var backdrop = document.getElementById('diag360backdrop');
    if (!el) return;
    function fechar(e) {
      if (e) { e.preventDefault(); e.stopPropagation(); }
      el.classList.remove('show');
      el.style.display = 'none';
      if (backdrop) { backdrop.classList.remove('show'); backdrop.style.display = 'none'; }
    }
    function abrir() {
      if (isDiagPage() || jaViu()) return;
      marcarVisto();
      el.classList.add('show');
      el.style.display = 'block';
      if (backdrop && isMobile()) { backdrop.classList.add('show'); backdrop.style.display = 'block'; }
    }
    var btnClose = document.getElementById('d360close');
    var btnSkip = document.getElementById('d360skip');
    if (btnClose) btnClose.addEventListener('click', fechar);
    if (btnSkip) btnSkip.addEventListener('click', fechar);
    if (backdrop) backdrop.addEventListener('click', fechar);
    function foraClick(e) {
      if (!el.classList.contains('show')) return;
      if (el.contains(e.target)) return;
      fechar(e);
    }
    document.addEventListener('mousedown', foraClick);
    document.addEventListener('touchstart', foraClick, { passive: true });
    setTimeout(abrir, isMobile() ? 3000 : 5000);
  } catch(e) {
    console.error('Popup diag360:', e);
  }
})();
</script>

