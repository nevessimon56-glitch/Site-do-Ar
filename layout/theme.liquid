    <script>
    (function () {
      var PANEL_SEL = '.sidenav-overlay, .sidenav-password, .sidenav-forgot-password';
      function panelIsOpen(panel) {
        return !!(panel && panel.classList && panel.classList.contains('open'));
      }
      document.addEventListener('focusin', function (e) {
        var target = e.target;
        if (!target || !target.closest || !target.matches('input, textarea, select')) return;
        var panel = target.closest(PANEL_SEL);
        if (panel && !panelIsOpen(panel)) {
          try { target.blur(); } catch (err) {}
        }
      }, true);
      function stripAutofocus() {
        var panels = document.querySelectorAll(PANEL_SEL);
        for (var i = 0; i < panels.length; i++) {
          if (panelIsOpen(panels[i])) continue;
          var inputs = panels[i].querySelectorAll('[autofocus]');
          for (var j = 0; j < inputs.length; j++) {
            inputs[j].removeAttribute('autofocus');
            inputs[j].setAttribute('data-autofocus-on-open', '1');
          }
        }
      }
      window.__stripHiddenAutofocus = stripAutofocus;
      document.addEventListener('DOMContentLoaded', stripAutofocus);
      if (typeof MutationObserver !== 'undefined') {
        var raf = 0;
        new MutationObserver(function () {
          if (raf) return;
          raf = requestAnimationFrame(function () { raf = 0; stripAutofocus(); });
        }).observe(document.documentElement, { childList: true, subtree: true });
      }
    })();
    </script>
</head>
