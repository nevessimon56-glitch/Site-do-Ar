{% assign seoTitle = '' %}
{% if product.seoTitle %}
    {% assign seoTitle = product.seoTitle %}
{% elsif search.results[0].categories[0].title %}
    {% assign seoTitle = search.results[0].categories[0].title %}
{% elsif seo.title %}
    {% assign seoTitle = seo.title %}
{% else %}
    {% assign seoTitle = 'Site Do Ar: Os Melhores Preços Aqui!!' %}
{% endif %}

{% assign seoDescription = '' %}
{% if product.seoDescription %}
    {% assign seoDescription = product.seoDescription %}
{% elsif search.results[0].categories[0].description %}
    {% assign seoDescription = search.results[0].categories[0].description %}
{% elsif seo.description %}
    {% assign seoDescription = seo.description %}
{% elsif store.description %}
    {% assign seoDescription = store.description %}
{% else %}
    {% assign seoDescription = 'Ar-condicionado em São Paulo com os melhores preços! Split, Inverter, portátil e mais em até 12x. Compre com instalação profissional no Site Do Ar. Confira!' %}
{% endif %}

{% assign seoKeywords = '' %}
{% if product.tags %}
    {% assign seoKeywords = product.tags %}
{% elsif search.results[0].categories[0].tags %}
    {% assign seoKeywords = search.results[0].categories[0].tags %}
{% elsif seo.keywords %}
    {% assign seoKeywords = seo.keywords %}
{% elsif store.keywords %}
    {% assign seoKeywords = store.keywords %}
{% endif %}

{% assign seoImage = '' %}
{% assign seoImageType = '' %}
{% assign seoImageWidth = '' %}
{% assign seoImageHeight = '' %}
{% if product.medias[0].path %}
    {% assign seoImage = product.medias[0].path | imgUrl: 200 %}
    {% if product.medias[0].mimeType %}
        {% assign seoImageType = product.medias[0].mimeType %}
    {% endif %}
    {% if product.medias[0].width %}
        {% assign seoImageWidth = product.medias[0].width %}
    {% endif %}
    {% if product.medias[0].height %}
        {% assign seoImageHeight = product.medias[0].height %}
    {% endif %}
{% elsif theme.logo.path %}
    {% assign seoImage = theme.logo.path | imgUrl %}
    {% if theme.logo.file.mimeType %}
        {% assign seoImageType = theme.logo.file.mimeType %}
    {% endif %}
    {% if theme.logo.width %}
        {% assign seoImageWidth = theme.logo.width %}
    {% endif %}
    {% if theme.logo.height %}
        {% assign seoImageHeight = theme.logo.height %}
    {% endif %}
{%endif%}

