<!-- Preço original riscado + 5% no Pix -->
<style>
  .showcase-prices_strike s,
  .product-prices_strike s {
    color: #94a3b8;
    font-weight: 600;
    text-decoration: line-through;
  }
  .showcase-prices_pix,
  .product-prices_pix {
    color: #16a34a;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.2;
    margin-top: 4px;
  }
  .showcase-prices_pix::before,
  .product-prices_pix::before {
    content: "● ";
    font-size: 10px;
    vertical-align: middle;
  }
  .product-prices .product-box_prices .product-prices_price {
    color: #2f5d8c;
    font-size: 36px;
    font-weight: 800;
    line-height: 1em;
  }
  .showcase-prices .showcase-prices_price b,
  .showcase-prices .showcase-prices_price {
    color: #2f5d8c;
  }
</style>
<script>
(function () {
  var PIX_DISCOUNT = 0.05;
  var PIX_LABEL = '5% de desconto no Pix';

  function parseBRL(text) {
    if (!text) return null;
    var cleaned = String(text).replace(/\s/g, '').replace(/[^\d,]/g, '').replace(',', '.');
    var value = parseFloat(cleaned);
    return isNaN(value) ? null : value;
  }

  function formatBRL(value) {
    return value.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
  }

  function originalFromPix(pixPrice) {
    return Math.round((pixPrice / (1 - PIX_DISCOUNT)) * 100) / 100;
  }

  function transformShowcasePrice(container) {
    if (!container || container.dataset.pixDone === '1') return;
    var priceNode = container.querySelector('.showcase-prices_price b, .showcase-prices_price');
    if (!priceNode) return;
    var pixPrice = parseBRL(priceNode.textContent);
    if (!pixPrice) return;

    var original = originalFromPix(pixPrice);
    container.innerHTML =
      '<p class="showcase-prices_strike"><s>' + formatBRL(original) + '</s></p>' +
      '<p class="showcase-prices_price"><b>' + formatBRL(pixPrice) + '</b></p>' +
      '<p class="showcase-prices_pix">' + PIX_LABEL + '</p>';
    container.dataset.pixDone = '1';
  }

  function transformProductPrice() {
    var box = document.querySelector('.product-prices .product-box_prices');
    if (!box || box.dataset.pixDone === '1') return;

    var priceNode = box.querySelector('.product-prices_price');
    if (!priceNode) return;

    var pixPrice = parseBRL(priceNode.textContent);
    if (!pixPrice) return;

    var original = originalFromPix(pixPrice);
    var plots = box.querySelector('.product-prices_plots');

    var strike = document.createElement('p');
    strike.className = 'product-prices_strike';
    strike.innerHTML = '<s>' + formatBRL(original) + '</s>';

    var pix = document.createElement('p');
    pix.className = 'product-prices_pix';
    pix.textContent = PIX_LABEL;

    priceNode.textContent = formatBRL(pixPrice);
    box.insertBefore(strike, priceNode);
    if (plots) box.insertBefore(pix, plots);
    else priceNode.insertAdjacentElement('afterend', pix);

    box.dataset.pixDone = '1';
  }

  function run() {
    document.querySelectorAll('.showcase-prices').forEach(transformShowcasePrice);
    transformProductPrice();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
  else run();

  var timer;
  new MutationObserver(function () {
    clearTimeout(timer);
    timer = setTimeout(run, 120);
  }).observe(document.body, { childList: true, subtree: true });
})();
</script>

<!-- Popup Diagnóstico Clima 360 -->
<style>
  #diag360backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 2147483646;
    background: rgba(0,0,0,0.55);
    -webkit-tap-highlight-color: transparent;
  }
  #diag360backdrop.show { display: block; }
  #diag360pop {
    display: none;
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 2147483647;
    width: 320px;
    max-width: calc(100vw - 32px);
    border-radius: 20px;
    background: linear-gradient(145deg, #111827, #0f172a);
    border: 1px solid rgba(249,115,22,0.4);
    box-shadow: 0 24px 64px rgba(0,0,0,0.7);
    padding: 24px;
    font-family: Arial, sans-serif;
    color: #f1f5f9;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }
  #diag360pop.show {
    display: block !important;
    animation: d360in 0.4s cubic-bezier(0.34,1.56,0.64,1) forwards;
  }
  @keyframes d360in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  #d360close {
    position: absolute; top: 12px; right: 14px;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
    border-radius: 50%; width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: #94a3b8; font-size: 14px; line-height: 1;
  }
  #d360close:hover { background: rgba(255,255,255,0.15); color: #fff; }
  .d360badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 10px; border-radius: 999px;
    background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.35);
    color: #fb923c; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 14px;
  }
  .d360dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #f97316; box-shadow: 0 0 6px #f97316;
    animation: d360pulse 1.8s infinite;
  }
  @keyframes d360pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
  .d360title { font-size: 16px; font-weight: 800; line-height: 1.3; margin: 0 0 8px; color: #f1f5f9; }
  .d360text  { font-size: 13px; color: #64748b; line-height: 1.55; margin: 0 0 14px; }
  .d360items { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
  .d360item  { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #94a3b8; }
  .d360item::before {
    content: "✓"; min-width: 18px; height: 18px; border-radius: 5px;
    background: rgba(249,115,22,0.15); color: #fb923c; font-size: 11px;
    font-weight: 900; display: flex; align-items: center; justify-content: center;
  }
  .d360cta {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 13px 20px; border-radius: 12px; border: 0;
    background: linear-gradient(135deg, #f97316, #fb923c);
    color: #fff !important; font-weight: 700; font-size: 14px;
    cursor: pointer; text-decoration: none !important;
    box-shadow: 0 6px 20px rgba(249,115,22,0.35); margin-bottom: 10px;
  }
  .d360cta:hover { opacity: 0.9; }
  .d360skip {
    display: block; text-align: center; color: #475569; font-size: 12px;
    cursor: pointer; background: none; border: 0; width: 100%;
    font-family: Arial, sans-serif; padding: 4px;
  }
  .d360skip:hover { color: #94a3b8; }
  @media (max-width: 767px) {
    #diag360pop {
      bottom: 0; right: 0; left: 0;
      width: 100%; max-width: 100%;
      border-radius: 20px 20px 0 0;
      padding: 20px 20px calc(20px + env(safe-area-inset-bottom, 0px));
      box-shadow: 0 -12px 48px rgba(0,0,0,0.6);
    }
  }
</style>

<div id="diag360backdrop" aria-hidden="true"></div>
<div id="diag360pop">
  <button id="d360close" type="button" aria-label="Fechar">&#x2715;</button>
  <div class="d360badge"><span class="d360dot"></span> Novo</div>
  <p class="d360title">Qual ar-condicionado é ideal para você?</p>
  <p class="d360text">Responda 10 perguntas e descubra a recomendação certa para o seu ambiente.</p>
  <div class="d360items">
    <span class="d360item">BTUs ideais para o seu espaço</span>
    <span class="d360item">Perfil personalizado de climatização</span>
    <span class="d360item">Link direto para os produtos certos</span>
  </div>
  <a class="d360cta" href="/pagina/diagnostico-360">&#127777; Fazer diagnóstico grátis</a>
  <button class="d360skip" id="d360skip" type="button">Agora não</button>
</div>

<script>
(function(){
  try {
    var KEY = 'diag360_dismissed';

    function isDiagPage() {
      var p = (window.location.pathname || '').toLowerCase();
      return p.indexOf('diagnostico') !== -1 || p.indexOf('diag360') !== -1;
    }

    function isMobile() {
      return window.matchMedia('(max-width: 767px)').matches;
    }

    function isLoggedIn() {
      try {
        return typeof customer !== 'undefined' && customer && (customer.customerId || customer.email);
      } catch (e) { return false; }
    }

    function jaViu() {
      if (!isLoggedIn()) return false;
      try { return localStorage.getItem(KEY) === '1'; } catch(e) { return false; }
    }

    function marcarVisto() {
      if (!isLoggedIn()) return;
      try { localStorage.setItem(KEY, '1'); } catch(e) {}
    }

    if (jaViu()) return;
    if (isDiagPage()) return;

    var el = document.getElementById('diag360pop');
    var backdrop = document.getElementById('diag360backdrop');
    if (!el) return;

    function fechar(e) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }
      el.classList.remove('show');
      el.style.display = 'none';
      if (backdrop) {
        backdrop.classList.remove('show');
        backdrop.style.display = 'none';
      }
      marcarVisto();
    }

    function abrir() {
      if (isDiagPage() || jaViu()) return;
      el.classList.add('show');
      el.style.display = 'block';
      if (backdrop && isMobile()) {
        backdrop.classList.add('show');
        backdrop.style.display = 'block';
      }
    }

    var btnClose = document.getElementById('d360close');
    var btnSkip = document.getElementById('d360skip');
    if (btnClose) btnClose.addEventListener('click', fechar);
    if (btnSkip) btnSkip.addEventListener('click', fechar);

    var cta = el.querySelector('.d360cta');
    if (cta) cta.addEventListener('click', marcarVisto);

    if (backdrop) backdrop.addEventListener('click', fechar);

    function foraClick(e) {
      if (!el.classList.contains('show')) return;
      if (el.contains(e.target)) return;
      fechar(e);
    }
    document.addEventListener('mousedown', foraClick);
    document.addEventListener('touchstart', foraClick, { passive: true });

    setTimeout(abrir, isMobile() ? 3000 : 5000);
  } catch(e) {
    console.error('Popup diag360:', e);
  }
})();
</script>

