{% comment %}
  Ícones de especificação — pills de texto (sem SVG, compatível mobile)
  VERSAO: 2026-07-15-spec-v4
  Lê a aba Especificações do produto (tabela HTML), atributos e título.
  Uso: {% render 'sections/product-spec-icons', product: product %}
{% endcomment %}

{% assign specTitle = product.title | downcase %}
{% assign specBlob = specTitle %}

{% if product.url and product.url != '' %}
  {% assign specBlob = specBlob | append: ' | ' | append: product.url | downcase %}
{% endif %}

{% if product.medias[0].path and product.medias[0].path != '' %}
  {% assign specBlob = specBlob | append: ' | ' | append: product.medias[0].path | downcase %}
{% endif %}
{% if product.medias[1].path and product.medias[1].path != '' %}
  {% assign specBlob = specBlob | append: ' | ' | append: product.medias[1].path | downcase %}
{% endif %}

{% if product.tags and product.tags != '' %}
  {% assign specBlob = specBlob | append: ' | ' | append: product.tags | downcase %}
{% endif %}

{% if product.shortDescription and product.shortDescription != '' %}
  {% assign specBlob = specBlob | append: ' | ' | append: product.shortDescription | downcase %}
{% endif %}

{% if product.seoDescription and product.seoDescription != '' %}
  {% assign specBlob = specBlob | append: ' | ' | append: product.seoDescription | downcase %}
{% endif %}

{% capture specHtmlRaw %}
{% if product.specification and product.specification != '' %}{{ product.specification }}{% endif %}
{% if product.specifications and product.specifications != '' %}{{ product.specifications }}{% endif %}
{% if product.specificationText and product.specificationText != '' %}{{ product.specificationText }}{% endif %}
{% if product.especificacao and product.especificacao != '' %}{{ product.especificacao }}{% endif %}
{% if product.especificacoes and product.especificacoes != '' %}{{ product.especificacoes }}{% endif %}
{% endcapture %}

{% assign specHtmlRaw = specHtmlRaw | strip %}
{% if specHtmlRaw != '' %}
  {% assign specPlain = specHtmlRaw
    | replace: '<br>', ' | '
    | replace: '<br/>', ' | '
    | replace: '<br />', ' | '
    | replace: '</tr>', ' | '
    | replace: '</td>', ' '
    | replace: '<td>', ' '
    | replace: '</th>', ' '
    | replace: '<th>', ' '
    | replace: '<tr>', ' '
    | replace: '<tbody>', ' '
    | replace: '</tbody>', ' '
    | replace: '<table>', ' '
    | replace: '</table>', ' '
    | replace: '<p>', ' '
    | replace: '</p>', ' '
    | replace: '<strong>', ' '
    | replace: '</strong>', ' '
    | replace: '<b>', ' '
    | replace: '</b>', ' '
    | downcase
  %}
  {% assign specBlob = specBlob | append: ' | ' | append: specPlain %}
{% endif %}

{% if product.attributes and product.attributes.size > 0 %}
  {% for attr in product.attributes %}
    {% assign attrName = attr.name | default: attr.nome | default: '' | downcase %}
    {% assign attrVal = '' %}
    {% if attr.values and attr.values.size > 0 %}
      {% assign attrVal = attr.values[0].name | default: attr.values[0].value | default: '' | downcase %}
    {% elsif attr.valores and attr.valores.size > 0 %}
      {% assign attrVal = attr.valores[0].nome | default: '' | downcase %}
    {% elsif attr.value %}
      {% assign attrVal = attr.value | downcase %}
    {% endif %}
    {% assign specBlob = specBlob | append: ' | ' | append: attrName | append: ':' | append: attrVal %}
  {% endfor %}
{% endif %}

{% if product.properties and product.properties.size > 0 %}
  {% for prop in product.properties %}
    {% assign propName = prop.name | default: prop.nome | default: '' | downcase %}
    {% assign propVal = prop.value | default: prop.valor | default: '' | downcase %}
    {% assign specBlob = specBlob | append: ' | ' | append: propName | append: ':' | append: propVal %}
  {% endfor %}
{% endif %}

{% comment %} Não usar product.description inteira — polui detecção (ex.: wi-fi em texto genérico) {% endcomment %}

{% assign iconProcelA = false %}
{% assign iconQuenteFrio = false %}
{% assign iconFrio = false %}
{% assign iconCobre = false %}
{% assign iconWifi = false %}
{% assign iconInverter = false %}
{% assign iconVoltage = '' %}

{% if specBlob contains 'procel' or specBlob contains 'classificação a' or specBlob contains 'classificacao a' or specBlob contains 'classificação energética a' or specBlob contains 'classificacao energetica a' or specBlob contains 'selo a' %}
  {% assign iconProcelA = true %}
{% endif %}

{% if specBlob contains 'ciclo: quente/frio' or specBlob contains 'ciclo: quente e frio' or specBlob contains 'ciclo quente/frio' or specBlob contains 'ciclo quente e frio' or specBlob contains 'quente/frio' or specBlob contains 'quente-frio' or specBlob contains 'quente e frio' or specBlob contains 'ciclo reverso' or specBlob contains ' q/f' or specBlob contains ' q-f' or specBlob contains '-quente-frio' or specBlob contains 'quente_frio' %}
  {% assign iconQuenteFrio = true %}
{% elsif specBlob contains 'ciclo: só frio' or specBlob contains 'ciclo: so frio' or specBlob contains 'ciclo só frio' or specBlob contains 'ciclo so frio' or specBlob contains 'ciclo: frio' or specBlob contains 'só frio' or specBlob contains 'so frio' or specBlob contains 'somente frio' or specBlob contains '-frio-' or specBlob contains '_frio_' or specBlob contains ' frio ' %}
  {% assign iconFrio = true %}
{% elsif specBlob contains 'frio' %}
  {% unless specBlob contains 'quente' %}
    {% assign iconFrio = true %}
  {% endunless %}
{% endif %}

{% if specBlob contains 'inverter' or specBlob contains 'inversor' or specBlob contains 'inversão' or specBlob contains 'inversao' %}
  {% assign iconInverter = true %}
{% endif %}

{% if specBlob contains 'cobre' or specBlob contains 'copper' %}
  {% unless specBlob contains 'alumínio' or specBlob contains 'aluminio' %}
    {% assign iconCobre = true %}
  {% endunless %}
{% endif %}

{% comment %}
  Wi-Fi: fonte conservadora (título + tabela de specs + atributos).
  Não usa tags, SEO, URL nem mídia — costumam marcar Wi-Fi errado em janela/mecânico.
{% endcomment %}
{% assign specWifiBlob = specTitle %}
{% if specHtmlRaw != '' %}
  {% assign specWifiBlob = specWifiBlob | append: ' | ' | append: specPlain %}
{% endif %}
{% if product.attributes and product.attributes.size > 0 %}
  {% for attr in product.attributes %}
    {% assign attrName = attr.name | default: attr.nome | default: '' | downcase %}
    {% assign attrVal = '' %}
    {% if attr.values and attr.values.size > 0 %}
      {% assign attrVal = attr.values[0].name | default: attr.values[0].value | default: '' | downcase %}
    {% elsif attr.valores and attr.valores.size > 0 %}
      {% assign attrVal = attr.valores[0].nome | default: '' | downcase %}
    {% elsif attr.value %}
      {% assign attrVal = attr.value | downcase %}
    {% endif %}
    {% assign specWifiBlob = specWifiBlob | append: ' | ' | append: attrName | append: ':' | append: attrVal %}
  {% endfor %}
{% endif %}
{% if product.properties and product.properties.size > 0 %}
  {% for prop in product.properties %}
    {% assign propName = prop.name | default: prop.nome | default: '' | downcase %}
    {% assign propVal = prop.value | default: prop.valor | default: '' | downcase %}
    {% assign specWifiBlob = specWifiBlob | append: ' | ' | append: propName | append: ':' | append: propVal %}
  {% endfor %}
{% endif %}

{% assign iconWifi = false %}
{% assign wifiBlocked = false %}

{% if specTitle contains 'mecânico' or specTitle contains 'mecanico' or specWifiBlob contains 'operação / controle | mecânico' or specWifiBlob contains 'operacao / controle | mecanico' or specWifiBlob contains 'mecânico (manual' or specWifiBlob contains 'mecanico (manual' or specWifiBlob contains 'botões rotativos' or specWifiBlob contains 'botoes rotativos' or specWifiBlob contains 'controle mecânico' or specWifiBlob contains 'controle mecanico' %}
  {% assign wifiBlocked = true %}
  {% assign iconInverter = false %}
{% endif %}

{% if specTitle contains 'janela' %}
  {% unless specTitle contains 'wi-fi' or specTitle contains 'wifi' %}
    {% assign wifiBlocked = true %}
  {% endunless %}
{% endif %}

{% if specWifiBlob contains 'compatibilidade wi-fi: não' or specWifiBlob contains 'compatibilidade wi-fi: nao' or specWifiBlob contains 'compatibilidade wifi: não' or specWifiBlob contains 'compatibilidade wifi: nao' or specWifiBlob contains 'sem wi-fi' or specWifiBlob contains 'sem wifi' or specWifiBlob contains 'não possui wi-fi' or specWifiBlob contains 'nao possui wi-fi' or specWifiBlob contains 'não possui wifi' or specWifiBlob contains 'nao possui wifi' %}
  {% assign wifiBlocked = true %}
{% endif %}

{% unless wifiBlocked %}
  {% if specWifiBlob contains 'compatibilidade wi-fi: sim' or specWifiBlob contains 'compatibilidade wifi: sim' or specWifiBlob contains 'wi-fi integrado' or specWifiBlob contains 'wifi integrado' or specWifiBlob contains 'wi-fi de fábrica' or specWifiBlob contains 'wi-fi de fabrica' or specWifiBlob contains 'smart wi-fi' or specWifiBlob contains 'smart wifi' %}
    {% assign iconWifi = true %}
  {% elsif specTitle contains ' wi-fi' or specTitle contains '-wi-fi' or specTitle contains 'wifi' %}
    {% assign iconWifi = true %}
  {% endif %}
{% endunless %}

{% if specBlob contains '220v' or specBlob contains '220 v' %}
  {% assign iconVoltage = '220V' %}
{% elsif specBlob contains '127v' or specBlob contains '127 v' %}
  {% assign iconVoltage = '127V' %}
{% elsif specBlob contains '110v' or specBlob contains '110 v' or specBlob contains '115v' or specBlob contains '115 v' %}
  {% assign iconVoltage = '110V' %}
{% elsif specBlob contains '380v' or specBlob contains '380 v' %}
  {% assign iconVoltage = '380V' %}
{% elsif specBlob contains 'bivolt' or specBlob contains 'bi-volt' or specBlob contains 'bi volt' %}
  {% assign iconVoltage = 'Bivolt' %}
{% endif %}

{% assign hasSpecIcons = false %}
{% if iconProcelA or iconQuenteFrio or iconFrio or iconCobre or iconWifi or iconInverter or iconVoltage != '' %}
  {% assign hasSpecIcons = true %}
{% endif %}

{% if hasSpecIcons %}
<ul class="showcase-spec-bar" data-spec-icons="v4" aria-label="Características do produto">
  {% if iconProcelA %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--procel" title="Classificação A — Procel">A</li>
  {% endif %}
  {% if iconQuenteFrio %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--cycle-qf" title="Quente e Frio">Q/F</li>
  {% endif %}
  {% if iconFrio and iconQuenteFrio == false %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--cycle-frio" title="Frio">Frio</li>
  {% endif %}
  {% if iconInverter %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--inverter" title="Tecnologia Inverter">Inverter</li>
  {% endif %}
  {% if iconCobre %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--cobre" title="Serpentina de Cobre">Cobre</li>
  {% endif %}
  {% if iconVoltage != '' %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--voltage" title="{{ iconVoltage }}">{{ iconVoltage }}</li>
  {% endif %}
  {% if iconWifi %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--wifi" title="Wi-Fi">Wi-Fi</li>
  {% endif %}
</ul>
{% endif %}
