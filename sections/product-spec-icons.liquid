{% comment %}
  Ícones de especificação — pills de texto (sem SVG, compatível mobile)
  Lê a aba Especificações do produto (tabela HTML), atributos e título.
  Uso: {% render 'sections/product-spec-icons', product: product %}
{% endcomment %}

{% assign specTitle = product.title | downcase %}
{% assign specBlob = specTitle %}

{% capture specHtmlRaw %}
{% if product.specification and product.specification != '' %}{{ product.specification }}{% endif %}
{% if product.specifications and product.specifications != '' %}{{ product.specifications }}{% endif %}
{% if product.specificationText and product.specificationText != '' %}{{ product.specificationText }}{% endif %}
{% if product.especificacao and product.especificacao != '' %}{{ product.especificacao }}{% endif %}
{% if product.especificacoes and product.especificacoes != '' %}{{ product.especificacoes }}{% endif %}
{% endcapture %}

{% assign specHtmlRaw = specHtmlRaw | strip %}
{% if specHtmlRaw != '' %}
  {% assign specPlain = specHtmlRaw
    | replace: '<br>', ' | '
    | replace: '<br/>', ' | '
    | replace: '<br />', ' | '
    | replace: '</tr>', ' | '
    | replace: '</td>', ' '
    | replace: '<td>', ' '
    | replace: '</th>', ' '
    | replace: '<th>', ' '
    | replace: '<tr>', ' '
    | replace: '<tbody>', ' '
    | replace: '</tbody>', ' '
    | replace: '<table>', ' '
    | replace: '</table>', ' '
    | replace: '<p>', ' '
    | replace: '</p>', ' '
    | replace: '<strong>', ' '
    | replace: '</strong>', ' '
    | replace: '<b>', ' '
    | replace: '</b>', ' '
    | downcase
  %}
  {% assign specBlob = specBlob | append: ' | ' | append: specPlain %}
{% endif %}

{% if product.attributes and product.attributes.size > 0 %}
  {% for attr in product.attributes %}
    {% assign attrName = attr.name | default: attr.nome | default: '' | downcase %}
    {% assign attrVal = '' %}
    {% if attr.values and attr.values.size > 0 %}
      {% assign attrVal = attr.values[0].name | default: attr.values[0].value | default: '' | downcase %}
    {% elsif attr.valores and attr.valores.size > 0 %}
      {% assign attrVal = attr.valores[0].nome | default: '' | downcase %}
    {% elsif attr.value %}
      {% assign attrVal = attr.value | downcase %}
    {% endif %}
    {% assign specBlob = specBlob | append: ' | ' | append: attrName | append: ':' | append: attrVal %}
  {% endfor %}
{% endif %}

{% if product.properties and product.properties.size > 0 %}
  {% for prop in product.properties %}
    {% assign propName = prop.name | default: prop.nome | default: '' | downcase %}
    {% assign propVal = prop.value | default: prop.valor | default: '' | downcase %}
    {% assign specBlob = specBlob | append: ' | ' | append: propName | append: ':' | append: propVal %}
  {% endfor %}
{% endif %}

{% if product.description %}
  {% assign specBlob = specBlob | append: ' | ' | append: product.description | downcase %}
{% endif %}

{% assign iconProcelA = false %}
{% assign iconQuenteFrio = false %}
{% assign iconFrio = false %}
{% assign iconCobre = false %}
{% assign iconWifi = false %}
{% assign iconVoltage = '' %}

{% if specBlob contains 'procel' or specBlob contains 'classificação a' or specBlob contains 'classificacao a' or specBlob contains 'classificação energética a' or specBlob contains 'classificacao energetica a' or specBlob contains 'selo a' %}
  {% assign iconProcelA = true %}
{% endif %}

{% if specBlob contains 'ciclo: quente/frio' or specBlob contains 'ciclo: quente e frio' or specBlob contains 'ciclo quente/frio' or specBlob contains 'ciclo quente e frio' or specBlob contains 'quente/frio' or specBlob contains 'quente-frio' or specBlob contains 'quente e frio' or specBlob contains 'ciclo reverso' or specBlob contains ' q/f' or specBlob contains ' q-f' %}
  {% assign iconQuenteFrio = true %}
{% elsif specBlob contains 'ciclo: só frio' or specBlob contains 'ciclo: so frio' or specBlob contains 'ciclo só frio' or specBlob contains 'ciclo so frio' or specBlob contains 'só frio' or specBlob contains 'so frio' or specBlob contains 'somente frio' %}
  {% assign iconFrio = true %}
{% elsif specBlob contains 'frio' %}
  {% unless specBlob contains 'quente' %}
    {% assign iconFrio = true %}
  {% endunless %}
{% endif %}

{% if specBlob contains 'cobre' or specBlob contains 'copper' %}
  {% unless specBlob contains 'alumínio' or specBlob contains 'aluminio' %}
    {% assign iconCobre = true %}
  {% endunless %}
{% endif %}

{% assign iconWifi = false %}
{% if specBlob contains 'compatibilidade wi-fi: sim' or specBlob contains 'compatibilidade wifi: sim' or specBlob contains 'wi-fi integrado' or specBlob contains 'wifi integrado' or specBlob contains 'wi-fi de fábrica' or specBlob contains 'wi-fi de fabrica' or specBlob contains 'com wi-fi' or specBlob contains 'com wifi' %}
  {% assign iconWifi = true %}
{% elsif specBlob contains 'compatibilidade wi-fi: não' or specBlob contains 'compatibilidade wi-fi: nao' or specBlob contains 'compatibilidade wifi: não' or specBlob contains 'compatibilidade wifi: nao' or specBlob contains 'compatibilidade wi-fi não' or specBlob contains 'compatibilidade wi-fi nao' or specBlob contains 'compatibilidade wifi não' or specBlob contains 'compatibilidade wifi nao' %}
  {% assign iconWifi = false %}
{% elsif specTitle contains 'wi-fi' or specTitle contains 'wifi' %}
  {% assign iconWifi = true %}
{% endif %}

{% if specBlob contains '220v' %}
  {% assign iconVoltage = '220V' %}
{% elsif specBlob contains '127v' %}
  {% assign iconVoltage = '127V' %}
{% elsif specBlob contains '380v' %}
  {% assign iconVoltage = '380V' %}
{% endif %}

{% assign hasSpecIcons = false %}
{% if iconProcelA or iconQuenteFrio or iconFrio or iconCobre or iconWifi or iconVoltage != '' %}
  {% assign hasSpecIcons = true %}
{% endif %}

{% if hasSpecIcons %}
<ul class="showcase-spec-bar" aria-label="Características do produto">
  {% if iconProcelA %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--procel" title="Classificação A — Procel">A</li>
  {% endif %}
  {% if iconQuenteFrio %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--cycle" title="Quente e Frio">Q/F</li>
  {% endif %}
  {% if iconFrio and iconQuenteFrio == false %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--cycle" title="Frio">Frio</li>
  {% endif %}
  {% if iconCobre %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--cobre" title="Serpentina de Cobre">Cobre</li>
  {% endif %}
  {% if iconVoltage != '' %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--voltage" title="{{ iconVoltage }}">{{ iconVoltage }}</li>
  {% endif %}
  {% if iconWifi %}
  <li class="showcase-spec-bar__tag showcase-spec-bar__tag--wifi" title="Wi-Fi">Wi-Fi</li>
  {% endif %}
</ul>
{% endif %}
