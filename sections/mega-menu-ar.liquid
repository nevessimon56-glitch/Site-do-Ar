{% comment %}
  Template do mega menu "Ar Condicionado".
  Carregado via theme.liquid; o JS move o painel para o header no desktop.
  Para trocar o banner: edite data-banner-url e o link em mega-menu-ar__banner-link.
{% endcomment %}

<div id="mega-menu-ar-template" class="d-hide" aria-hidden="true">
  <div class="mega-menu-ar__inner">
    <div class="mega-menu-ar__grid">

      <div class="mega-menu-ar__col">
        <h3 class="mega-menu-ar__col-title">Split Inverter</h3>
        <ul class="mega-menu-ar__links">
          <li><a href="/split-inverter/9000-btus">9000 BTUs</a></li>
          <li><a href="/split-inverter/12000-Btus">12000 BTUs</a></li>
          <li><a href="/split-inverter/18000-Btus">18000 BTUs</a></li>
