{% comment %}
  ARQUIVO: showcase-model-product.liquid
  VERSAO: 2026-07-15-v4  (nao usa primaryPrice / tabela Mercado Livre)
  No editor WDNA: substitua TODO o conteudo deste arquivo.
  Preco Pix + parcelas estao INLINE neste arquivo (nao depende de outro).
  Os icones de spec ficam APENAS em showcase-spec-wrap (abaixo do titulo).
  VALIDAR: deve existir "productPricePrimary = product.price" e NAO deve existir "product.primaryPrice"
{% endcomment %}
{% assign maximumProducts = 60 %}
{% assign products = showcaseSection.products %}
{% if sectionConfig.rowQuantity and sectionConfig.columnQuantity %}
    {% assign maximumProducts = sectionConfig.rowQuantity | times: sectionConfig.columnQuantity %}
{% endif %}
{% if products %}
    {% assign products = products %}
{% endif %}
{% for product in products limit: maximumProducts %}

    {% assign buyButtonText = 'Comprar' %}
    {% if product.customBuyButton and product.customBuyButton.type == 'product' %}
        {% assign buyButtonText = 'Ver mais' %}
        {% if product.customBuyButton.text and product.customBuyButton.text != '' %}
            {% assign buyButtonText = product.customBuyButton.text %}
        {% endif %}
    {% endif %}

    {% assign productPricePrimary = product.price %}

    {% assign listPriceCard = product.price.price %}
    {% assign pixPriceCard = product.price.price %}
    {% assign hasPixPromoCard = 0 %}
    {% assign pixPercentCard = 5 %}
    {% assign offerPercentCard = 5 %}

    {% if product.price.promotionMargin > 0 and product.price.promotionPrice != null %}
        {% assign hasPixPromoCard = 1 %}
        {% assign pixPriceCard = product.price.promotionPrice %}
        {% assign pixPercentCard = product.price.promotionMargin | round %}
        {% assign offerPercentCard = pixPercentCard %}
    {% endif %}

    <li class="showcase-item" data-showcase-tpl="v3-site-price">
        <div class="showcase-product card">
            {% if themeConfig.price.type != 'hide' %}
                {% if product.promotion %}
                    <div class="showcase-tag">
                        {{ product.promotion.label }}
                    </div>
                {% endif %}
                {% if product.freeShipping == true %}
                    <div class="showcase-tag showcase-tag-free_shipping">
                        Frete Grátis
                    </div>
                {% endif %}
            {% endif %}
            <div class="showcase-product_image card-image">
                {% if themeConfig.price.type != 'hide' %}
                    {% if hasPixPromoCard == 1 %}
                        {% assign classBtnBuy = '' %}
                        {% if themeConfig.price.type == 'show-logged' %}
                            {% assign classBtnBuy = ' login-btn_logged d-hide' %}
                        {% endif %}
                        <div class="showcase-offer{{ classBtnBuy }}">
                            <div class="showcase-offer_text">
                                <span>{{ offerPercentCard }}%</span>
                                <span>OFF</span>
                            </div>
                        </div>
                    {% endif %}
                {% endif %}
                <a class="showcase-product_link showcase-product_link__image" href="{{ product.url }}">
                    {% if product.medias[0].path != blank %}
                        <img
                            class="lazy product-hover-swap"
                            data-src="{{ product.medias[0].path | imgUrl: 250 }}"
                            {% if product.medias[1].path != blank %}data-hover-src="{{ product.medias[1].path | imgUrl: 250 }}"{% endif %}
                            alt="{{ product.title }}">
                    {% else %}
                        {{ themeConfig.icons.image }}
                    {% endif %}
                </a>
            </div>
            <div class="card-header">
                <h3>
                    {% assign productTitle = product.title %}
                    {% if product.multiple > 1 %}
                        {% assign productTitle = productTitle | append: ' - ' | append: product.multiple %}
                        {% if product.unitName %}
                            {% assign productUnitName = product.unitName | downcase %}
                            {% assign productTitle = productTitle | append: ' ' | append: productUnitName | append: 's' %}
                        {% endif %}
                    {% endif %}
                    <a class="showcase-product_link showcase-product_link_title" href="{{ product.url }}" title="{{ productTitle }}">
                        {{ productTitle }}
                    </a>
                </h3>
            </div>
            <div class="showcase-spec-wrap">
                {% render 'sections/product-spec-icons', product: product %}
            </div>
            <div class="card-footer">
                {% if product.price.showPrice == false and themeConfig.buyAction.type != 'hide' %}
                    <div class="showcase-prices"></div>
                    {% assign msgChatContact = 'Olá, gostaria de saber preço do produto:%0A%0A'| append: product.title | append: '%0AID: ' | append: product.id %}
                    <a class="showcase-product_buy btn" href="javascript:void(0)" onclick="handleAddToCart('{{ product.id }}')">
                        Sob consulta
                    </a>
                {% else %}
                    {% if themeConfig.price.type == 'show' or themeConfig.price.type == 'show-logged' %}
                        {% assign classShowcaseLoginPrice = '' %}
                        {% if themeConfig.price.type == 'show-logged' %}
                            {% assign classShowcaseLoginPrice = ' login-btn_logged d-hide' %}
                        {% endif %}
                        <div class="showcase-prices showcase-prices--card{{ classShowcaseLoginPrice }}">
                            {% if hasPixPromoCard == 1 %}
                                {% if listPriceCard > pixPriceCard %}
                                    <del class="showcase-prices_strike"><s>{{ listPriceCard | money }}</s></del>
                                {% endif %}
                                <p class="showcase-prices_price showcase-prices_price--pix"><b>{{ pixPriceCard | money }}</b></p>
                                <p class="showcase-prices_pix"><span>{{ pixPercentCard }}</span>% off no Pix</p>
                            {% else %}
                                <p class="showcase-prices_price"><b>{{ productPricePrimary.price | money }}</b></p>
                            {% endif %}
                            {% if product.secondaryPrice %}
                                {% if product.secondaryPrice.installment > 1 %}
                                {% assign plotBasePrice = listPriceCard %}
                                {% if product.secondaryPrice.price and product.secondaryPrice.price > plotBasePrice %}
                                    {% assign plotBasePrice = product.secondaryPrice.price %}
                                {% endif %}
                                <p class="showcase-prices_installment" data-plot-base="{{ plotBasePrice }}" data-plot-count="{{ product.secondaryPrice.installment }}">
                                    <span class="showcase-prices_installment-prefix">ou</span>
                                    <span class="showcase-prices_installment-text">em até <b>{{ product.secondaryPrice.installment }}x</b> de <b class="showcase-prices_installment-value">{{ plotBasePrice | divided_by: product.secondaryPrice.installment | money }}</b> sem juros</span>
                                </p>
                                {% endif %}
                            {% endif %}
                        </div>
                    {% endif %}
                    <a class="showcase-product_buy btn" href="javascript:void(0)" onclick="handleAddToCart('{{ product.id }}')">
                        Comprar
                    </a>
                {% endif %}
            </div>
        </div>
    </li>
{% endfor %}
