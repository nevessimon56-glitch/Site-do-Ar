{% comment %}
  Preços do card — Pix + parcelas no cartão (valor cheio)
  SITE-PRICE-RESOLVE-v2: mesmo preco para visitante e logado (nunca ML)
  Uso: {% render 'sections/showcase-prices', product: product %}
{% endcomment %}

{% assign sitePrice = nil %}
{% render 'sections/site-price-resolve', product: product %}

{% assign listPriceCard = sitePrice.price %}
{% assign pixPriceCard = sitePrice.price %}
{% assign hasPixPromoCard = 0 %}
{% assign pixPercentCard = 5 %}

{% if sitePrice.promotionMargin > 0 and sitePrice.promotionPrice != null %}
  {% assign hasPixPromoCard = 1 %}
  {% assign pixPriceCard = sitePrice.promotionPrice %}
  {% assign pixPercentCard = sitePrice.promotionMargin | round %}
{% endif %}

{% if hasPixPromoCard == 1 %}
  {% if listPriceCard > pixPriceCard %}
    <del class="showcase-prices_strike"><s>{{ listPriceCard | money }}</s></del>
  {% endif %}
  <p class="showcase-prices_price showcase-prices_price--pix"><b>{{ pixPriceCard | money }}</b></p>
  <p class="showcase-prices_pix"><span>{{ pixPercentCard }}</span>% off no Pix</p>
{% else %}
  <p class="showcase-prices_price"><b>{{ sitePrice.price | money }}</b></p>
{% endif %}

{% if product.secondaryPrice %}
  {% if product.secondaryPrice.installment > 1 %}
    {% assign plotBasePrice = listPriceCard %}
    {% if product.secondaryPrice.price and product.secondaryPrice.price > plotBasePrice %}
      {% assign plotBasePrice = product.secondaryPrice.price %}
    {% endif %}
    <p class="showcase-prices_installment" data-plot-base="{{ plotBasePrice }}" data-plot-count="{{ product.secondaryPrice.installment }}">
      <span class="showcase-prices_installment-prefix">ou</span>
      <span class="showcase-prices_installment-text">em até <b>{{ product.secondaryPrice.installment }}x</b> de <b class="showcase-prices_installment-value">{{ plotBasePrice | divided_by: product.secondaryPrice.installment | money }}</b> sem juros</span>
    </p>
  {% endif %}
{% endif %}
