{% assign _pixPrice = productPricePrimary.price %}
{% if productPricePrimary.promotionPrice > 0 %}
  {% assign _pixPrice = productPricePrimary.promotionPrice %}
{% endif %}

{% assign _hasPixDiscount = false %}
{% if product.primaryPrice and product.price.price > _pixPrice %}
  {% assign _hasPixDiscount = true %}
{% endif %}

{% if _hasPixDiscount %}
  <del class="product-prices_strike"><s>{{ product.price.price | money }}</s></del>
  <p class="product-prices_price">{{ _pixPrice | money }}</p>
  <p class="product-prices_pix">
    {% if productPricePrimary.discountPercentage and productPricePrimary.discountPercentage > 0 %}
      {{ productPricePrimary.discountPercentage | round }}% de desconto no Pix
    {% else %}
      5% de desconto no Pix
    {% endif %}
  </p>
{% else %}
  {% if productPricePrimary.promotionPrice > 0 and productPricePrimary.price > productPricePrimary.promotionPrice %}
    <del class="product-prices_strike">{{ productPricePrimary.price | money }}</del>
  {% endif %}
  <p class="product-prices_price">{{ _pixPrice | money }}</p>
{% endif %}

{% if productPriceSecond %}
  {% assign _mainPriceSecond = productPriceSecond.price %}
  {% if productPriceSecond.promotionPrice > 0 %}{% assign _mainPriceSecond = productPriceSecond.promotionPrice %}{% endif %}
  {% if productPriceSecond.installment > 1 %}
    <p class="product-prices_plots">{{ productPriceSecond.installment }}x de {{ productPriceSecond.installmentValue | money }} no cartão</p>
  {% else %}
    <p class="product-prices_plots">ou {{ _mainPriceSecond | money }} à vista</p>
  {% endif %}
{% endif %}
